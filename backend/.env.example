# SWM backend runtime config — copy to backend/.env and fill in.
# backend/.env is gitignored; NEVER commit real secrets.

# dev | prod. In prod the server refuses to start with weak/default secrets.
APP_ENV=dev

HTTP_ADDR=:8080
DATABASE_URL=user:pass@tcp(localhost:3306)/swmanager?charset=utf8mb4&parseTime=true&loc=Local&multiStatements=true
REDIS_URL=redis://localhost:6379/0

# Auth secrets. PROD: each must be a strong, non-default value of >= 32 chars.
JWT_SECRET=
JWT_ISSUER=swm
# Master key that encrypts per-app client secrets at rest (do not lose it).
APP_SECRET_MASTER_KEY=

# --- Device authorization signing (Ed25519) ---
# The server signs each authorization verdict; the client verifies it with the
# matching PUBLIC key embedded in SwmConfig.AuthzPublicKeys.
#
# DEV: leave these BLANK to use the built-in dev key, which already matches the
#      client's "authz-dev" public key — no coordination needed locally.
# PROD: generate a keypair with `./build.sh genkeys`, put the PRIVATE key here
#       (or in your secrets manager) and add the PUBLIC key to the client build.
#       Do NOT regenerate per build — it would lock out distributed clients.
AUTHZ_KEY_ID=
AUTHZ_SIGNING_PRIVATE_KEY=
# Per-app authz keys: when true (default), the platform key above signs verdicts
# for apps that have no active per-app key (keeps already-distributed clients
# working during migration). Set false only after every app has its own key and
# all clients have updated; then apps without a key fail closed and the platform
# key may be retired.
AUTHZ_PLATFORM_FALLBACK=true

STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./data/files
LOCAL_PUBLIC_BASE_URL=http://localhost:8088/files

# S3 / MinIO (only when STORAGE_DRIVER=s3). PROD: replace default credentials.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=swm
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

RUN_MIGRATIONS=true
ENABLE_EMBEDDED_WORKER=true
WORKER_INTERVAL_SECONDS=3600

IP2REGION_V4_XDB_PATH=./third_party/ip2region/data/ip2region_v4.xdb
IP2REGION_V6_XDB_PATH=./third_party/ip2region/data/ip2region_v6.xdb
IP2REGION_REGION_CSV_PATH=./third_party/ip2region/data/global_region.csv

# --- 阿里云 ESA 托管转换头（真实 IP / 地域识别）---
# 仅当确认回源流量"必经 ESA"时把 ESA_GEO_HEADERS_TRUSTED 设为 true，否则普通客户端
# 可伪造 ali-ip-country 等头绕过地域限制。本地/未接 ESA 时保持 false。
ESA_GEO_HEADERS_TRUSTED=false
# 头名通常用默认即可；仅当在 ESA 控制台自定义了头名时才需修改。
ESA_REAL_IP_HEADER=ali-real-client-ip
ESA_IP_COUNTRY_HEADER=ali-ip-country
ESA_IP_CITY_HEADER=ali-ip-city
# 地域来源"服务端优先"总开关（防伪造）：
#   true（默认/推荐）= ESA > ip2region > 客户端自报（客户端自报降为最低兜底）；
#   false           = 回退旧版"客户端自报最优先"。
# 注意：true 时即使未接 ESA 也会用 ip2region 覆盖客户端自报的地域（有意的防伪造变更）。
PREFER_SERVERSIDE_REGION=true

# Comma-separated allowed origins. PROD: set explicit origins, not "*".
CORS_ORIGINS=*
