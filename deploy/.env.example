APP_ENV=prod
HTTP_ADDR=:8080
DATABASE_URL=swm:swm@tcp(localhost:3306)/swmanager?charset=utf8mb4&parseTime=true&loc=Local&multiStatements=true
# PROD: replace with strong, non-default values (>= 32 chars). The server refuses
# to start in prod with these dev placeholders.
JWT_SECRET=CHANGE_ME_strong_random_min_32_chars
JWT_ISSUER=swm
APP_SECRET_MASTER_KEY=CHANGE_ME_strong_random_min_32_chars
# Device authorization signing. Generate with `./build.sh genkeys`, then embed the
# matching PUBLIC key in the client (SwmConfig.AuthzPublicKeys) under this key_id.
AUTHZ_KEY_ID=CHANGE_ME
AUTHZ_SIGNING_PRIVATE_KEY=CHANGE_ME_ed25519_seed_hex
CORS_ORIGINS=http://localhost:5173
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./data/files
LOCAL_PUBLIC_BASE_URL=http://localhost:8088/files
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=swm
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
RUN_MIGRATIONS=true
