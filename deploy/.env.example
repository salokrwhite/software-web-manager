APP_ENV=prod
HTTP_ADDR=:8080
DATABASE_URL=swm:swm@tcp(localhost:3306)/swmanager?charset=utf8mb4&parseTime=true&loc=Local&multiStatements=true
# PROD: replace with strong, non-default values (>= 32 chars). The server refuses
# to start in prod with these dev placeholders.
JWT_SECRET=CHANGE_ME_strong_random_min_32_chars
JWT_ISSUER=swm
APP_SECRET_MASTER_KEY=CHANGE_ME_strong_random_min_32_chars
# Device authorization signing. Generate with `./build.sh genkeys`, then embed the
# matching PUBLIC key in the client (SwmConfig.AuthzPublicKeys) under this key_id.
AUTHZ_KEY_ID=CHANGE_ME
AUTHZ_SIGNING_PRIVATE_KEY=CHANGE_ME_ed25519_seed_hex
# true (default): platform key signs for apps without a per-app key (migration
# safety). Set false only after every app has its own key and clients updated.
AUTHZ_PLATFORM_FALLBACK=true
CORS_ORIGINS=http://localhost:5173
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./data/files
LOCAL_PUBLIC_BASE_URL=http://localhost:8088/files
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=swm
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
RUN_MIGRATIONS=true

IP2REGION_V4_XDB_PATH=./third_party/ip2region/data/ip2region_v4.xdb
IP2REGION_V6_XDB_PATH=./third_party/ip2region/data/ip2region_v6.xdb
IP2REGION_REGION_CSV_PATH=./third_party/ip2region/data/global_region.csv

# --- 阿里云 ESA 托管转换头（真实 IP / 地域识别）---
# 仅当回源流量"必经 ESA"时设 true，否则可被客户端伪造绕过地域限制。
ESA_GEO_HEADERS_TRUSTED=false
ESA_REAL_IP_HEADER=ali-real-client-ip
ESA_IP_COUNTRY_HEADER=ali-ip-country
ESA_IP_CITY_HEADER=ali-ip-city
# 服务端优先（防伪造）总开关：true=ESA>ip2region>客户端自报（推荐）；false=旧版客户端自报最优先。
PREFER_SERVERSIDE_REGION=true
