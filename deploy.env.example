# 部署配置示例文件
# 使用方法：
# 1. 复制此文件为 deploy.env
# 2. 根据实际需求修改配置
# 3. 运行：source deploy.env && ./build.sh
# 或者：export VITE_API_BASE=xxx && export BUILD_WORKER_COMPAT=false && ./build.sh

# ========== 生产环境 API 地址 ==========
# 请修改为实际的后端服务器地址
# 示例：
#   http://192.168.1.100:8080
#   https://api.yourdomain.com
export VITE_API_BASE=http://localhost:8080

# ========== Worker 兼容模式 ==========
# true: 编译 swm-worker（兼容模式，双二进制文件)
# false: 跳过 swm-worker 编译（单二进制优先）
export BUILD_WORKER_COMPAT=true
